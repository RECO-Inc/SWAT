# Docker Hub image references used by docker-compose.yml.
# Copy to .env and replace <dockerhub-username> with your account.
API_IMAGE=<dockerhub-username>/swat-api:latest
FRONTEND_IMAGE=<dockerhub-username>/swat-frontend:latest

# Build-time only: baked into the static frontend bundle.
# Leave empty so the browser calls the API same-origin through nginx (/api).
# Only set this if you serve the API on a different origin.
VITE_API_BASE_URL=

# Optional runtime overrides.
MAX_UPLOAD_BYTES=102400
FRONTEND_PORT=19090
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=swat
HAPROXY_STATS_PORT=8404

# reco-ss-xeon (192.168.0.9) — avoid 3000/9090/30000 used by other stacks:
# FRONTEND_PORT=19090
# PROMETHEUS_PORT=19095
# GRAFANA_PORT=19092
# HAPROXY_STATS_PORT=19096

# OCR integration. Leave OCR_API_URL empty to disable OCR forwarding
# (async uploads are accepted and marked "disabled"; sync uploads return 503).
# Set it to the OCR service base URL to enable both async and sync OCR.
OCR_API_URL=http://192.168.0.9:8718
OCR_MAP=true
# 0 = no per-call timeout, so queued async OCR jobs run to completion.
OCR_TIMEOUT_MS=0
OCR_ASYNC_WORKERS=16
OCR_ASYNC_QUEUE=1024
# 0 = no HTTP write timeout, so slow synchronous OCR is not reset mid-request.
API_WRITE_TIMEOUT_MS=0
